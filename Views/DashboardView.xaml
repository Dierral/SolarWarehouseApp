<Page x:Class="SolarWarehouseApp.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesign.Brush.Background}"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- Greeting section -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="GreetingText" FontSize="28" FontWeight="Bold"
                               Foreground="#FF6D00" Margin="0,0,0,4"/>
                    <TextBlock x:Name="DateTimeText" FontSize="14" Foreground="#9E9E9E"/>
                </StackPanel>

                <!-- Solar logo decoration -->
                <Grid Grid.Column="1" Width="60" Height="60" VerticalAlignment="Center">
                    <Ellipse>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF6D00" Offset="0"/>
                                <GradientStop Color="#FFD600" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <materialDesign:PackIcon Kind="WeatherSunny" Width="36" Height="36"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- Stats cards row -->
            <UniformGrid Columns="4" Margin="0,0,0,24">

                <!-- Total items card -->
                <materialDesign:Card Margin="0,0,12,0" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF6D00" Offset="0"/>
                                <GradientStop Color="#E65100" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="20,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="Warehouse" Width="28" Height="28" Foreground="White" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock x:Name="TotalItemsCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Товарів на складі" FontSize="12" Foreground="White" Opacity="0.85"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

                <!-- Recent supplies card -->
                <materialDesign:Card Margin="0,0,12,0" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0F3460" Offset="0"/>
                                <GradientStop Color="#16213E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="20,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="TruckDelivery" Width="28" Height="28" Foreground="#FF6D00" Opacity="0.9"/>
                            </StackPanel>
                            <TextBlock x:Name="SuppliesCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Поставок (30 днів)" FontSize="12" Foreground="White" Opacity="0.75"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

                <!-- Equipment types card -->
                <materialDesign:Card Margin="0,0,12,0" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD600" Offset="0"/>
                                <GradientStop Color="#F57F17" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="20,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="SolarPanel" Width="28" Height="28" Foreground="White" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock x:Name="EquipmentTypesCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Типів обладнання" FontSize="12" Foreground="White" Opacity="0.85"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>

                <!-- Manufacturers card -->
                <materialDesign:Card Margin="0" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1B5E20" Offset="0"/>
                                <GradientStop Color="#2E7D32" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="20,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="Factory" Width="28" Height="28" Foreground="White" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock x:Name="ManufacturersCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Виробників" FontSize="12" Foreground="White" Opacity="0.85"/>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Recent supplies table -->
            <materialDesign:Card UniformCornerRadius="12"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <Border BorderBrush="#1F2937" BorderThickness="0,0,0,1" Padding="20,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockOutline" Width="20" Height="20"
                                                     VerticalAlignment="Center" Foreground="#FF6D00"/>
                            <TextBlock Text="Останні поставки" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="RecentSuppliesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              Margin="0" MaxHeight="320"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding SupplyDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="130"/>
                            <DataGridTextColumn Header="Тип обладнання" Binding="{Binding EquipmentType}" Width="*"/>
                            <DataGridTextColumn Header="Виробник" Binding="{Binding Manufacturer}" Width="140"/>
                            <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Тип" Binding="{Binding SupplyType}" Width="120"/>
                            <DataGridTextColumn Header="Хто додав" Binding="{Binding CreatedBy}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
