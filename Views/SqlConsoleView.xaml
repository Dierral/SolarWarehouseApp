<Page x:Class="SolarWarehouseApp.Views.SqlConsoleView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesign.Brush.Background}"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SQL input card -->
        <materialDesign:Card Grid.Row="0" UniformCornerRadius="10" Margin="0,0,0,8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Orientation="Horizontal" Margin="12,8">
                <materialDesign:PackIcon Kind="Console" Width="20" Height="20"
                                         Foreground="#FF6D00" VerticalAlignment="Center"/>
                <TextBlock Text="SQL-консоль" FontSize="15" FontWeight="SemiBold"
                           Foreground="#FF6D00" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- SQL editor -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="10" Margin="0,0,0,8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <TextBox x:Name="SqlInput"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="14"
                     Margin="12"
                     Background="Transparent"
                     materialDesign:HintAssist.Hint="Введіть SQL-запит..."
                     Style="{StaticResource MaterialDesignTextBox}"
                     KeyDown="SqlInput_KeyDown"/>
        </materialDesign:Card>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Background="#FF6D00" Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="Execute_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center"/>
                    <TextBlock Text="Виконати (F5)" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="Clear_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Eraser" VerticalAlignment="Center"/>
                    <TextBlock Text="Очистити" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="#9E9E9E" FontSize="12" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Results grid -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      Style="{StaticResource MaterialDesignDataGrid}"/>
        </materialDesign:Card>
    </Grid>
</Page>
