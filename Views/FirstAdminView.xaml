<Window x:Class="SolarWarehouseApp.Views.FirstAdminView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Solar Warehouse — Створення адміністратора"
        Width="500" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#16213E" Offset="0.5"/>
                <GradientStop Color="#0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <materialDesign:Card Margin="40" VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp8"
                             Background="#16213E" UniformCornerRadius="16">
            <StackPanel Margin="40,36,40,40">

                <!-- Solar icon -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Width="72" Height="72">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF6D00" Offset="0"/>
                                <GradientStop Color="#FFD600" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <materialDesign:PackIcon Kind="ShieldAccount" Width="40" Height="40"
                                             Foreground="White" HorizontalAlignment="Center"
                                             Margin="0,-56,0,0"/>
                </StackPanel>

                <TextBlock Text="Перше налаштування" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#FF6D00"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Створіть акаунт адміністратора системи" FontSize="12"
                           HorizontalAlignment="Center" Foreground="#9E9E9E"
                           Margin="0,0,0,28" TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Login field -->
                <TextBox x:Name="LoginBox"
                         materialDesign:HintAssist.Hint="Логін (мін. 3 символи)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="White"
                         Margin="0,0,0,16" FontSize="14"/>

                <!-- Password field -->
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Пароль (мін. 6 символів)"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Foreground="White"
                             Margin="0,0,0,16" FontSize="14"/>

                <!-- Confirm password -->
                <PasswordBox x:Name="ConfirmBox"
                             materialDesign:HintAssist.Hint="Підтвердити пароль"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Foreground="White"
                             Margin="0,0,0,28" FontSize="14"/>

                <!-- Create button -->
                <Button Background="#FF6D00" Foreground="White" FontSize="14"
                        Height="44" materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="CreateButton_Click"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="СТВОРИТИ АДМІНІСТРАТОРА" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Error/status message -->
                <TextBlock x:Name="StatusMessage" Text="" Foreground="#EF5350"
                           HorizontalAlignment="Center" FontSize="12"
                           Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
