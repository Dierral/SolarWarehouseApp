<Window x:Class="SolarWarehouseApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Solar Warehouse — Авторизація"
        Width="480" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="SolarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#FF6D00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#16213E" Offset="0.5"/>
                <GradientStop Color="#0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative solar circles -->
        <Ellipse Width="300" Height="300" Opacity="0.05"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-80,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#FF6D00" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="200" Height="200" Opacity="0.06"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-60,0,0,-60">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#FFD600" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Main card -->
        <materialDesign:Card Margin="40" VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp8"
                             Background="#16213E" UniformCornerRadius="16">
            <StackPanel Margin="40,36,40,40">

                <!-- Solar icon -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Width="72" Height="72">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF6D00" Offset="0"/>
                                <GradientStop Color="#FFD600" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <materialDesign:PackIcon Kind="WeatherSunny" Width="40" Height="40"
                                             Foreground="White" HorizontalAlignment="Center"
                                             Margin="0,-56,0,0"/>
                </StackPanel>

                <!-- Title -->
                <TextBlock Text="Solar Warehouse" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#FF6D00"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Система управління складом" FontSize="12"
                           HorizontalAlignment="Center" Foreground="#9E9E9E"
                           Margin="0,0,0,28"/>

                <!-- Login field -->
                <TextBox x:Name="LoginBox"
                         materialDesign:HintAssist.Hint="Логін"
                         materialDesign:HintAssist.FloatingScale="0.85"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="White"
                         materialDesign:TextFieldAssist.UnderlineBrush="#FF6D00"
                         materialDesign:ColorZoneAssist.Mode="PrimaryDark"
                         Margin="0,0,0,16"
                         FontSize="14"
                         KeyDown="LoginBox_KeyDown"/>

                <!-- Password field -->
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Пароль"
                             materialDesign:HintAssist.FloatingScale="0.85"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Foreground="White"
                             Margin="0,0,0,28"
                             FontSize="14"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Login button -->
                <Button Style="{StaticResource SolarButton}"
                        Click="LoginButton_Click"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Login" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="УВІЙТИ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Error message -->
                <TextBlock x:Name="ErrorMessage" Text="" Foreground="#EF5350"
                           HorizontalAlignment="Center" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
