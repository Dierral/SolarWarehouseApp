<Page x:Class="SolarWarehouseApp.Views.UsersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesign.Brush.Background}"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Margin="12,12,12,6" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Orientation="Horizontal" Margin="16,10">
                <Button Background="#FF6D00" Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Click="Add_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center"/>
                        <TextBlock Text="Додати" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Click="Edit_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center"/>
                        <TextBlock Text="Редагувати" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Foreground="#EF5350" BorderBrush="#EF5350"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Click="Delete_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountRemove" VerticalAlignment="Center"/>
                        <TextBlock Text="Видалити" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#9E9E9E" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center"/>
                        <TextBlock Text="Оновити" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Margin="12,0,12,12" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <DataGrid x:Name="Grid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      MouseDoubleClick="Grid_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Логін" Binding="{Binding Login}" Width="200"/>
                    <DataGridTextColumn Header="Пароль" Binding="{Binding PasswordHash}" Width="200"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Активний" Binding="{Binding IsActive}" Width="100"/>
                    <DataGridTextColumn Header="Оновлено" Binding="{Binding UpdatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</Page>
