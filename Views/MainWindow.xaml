<Window x:Class="SolarWarehouseApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Solar Warehouse"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FF6D00"/>
                                <Setter Property="Foreground" Value="#FF6D00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FF6D00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar button style -->
        <Style x:Key="SidebarButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Foreground" Value="#FF6D00"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#22FF6D00" CornerRadius="8" Margin="6,2">
                            <Grid>
                                <Rectangle Width="3" HorizontalAlignment="Left" Fill="#FF6D00" RadiusX="2" RadiusY="2"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FF6D00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border x:Name="Sidebar" Grid.Column="0" Width="64"
                Background="#111827" Panel.ZIndex="10"
                MouseEnter="Sidebar_MouseEnter" MouseLeave="Sidebar_MouseLeave">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.4" ShadowDepth="2" Direction="0"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SidebarPanel">
                    <!-- Logo area -->
                    <Border Height="70" Background="#0F172A" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Ellipse Width="36" Height="36">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF6D00" Offset="0"/>
                                        <GradientStop Color="#FFD600" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <materialDesign:PackIcon Kind="WeatherSunny" Width="22" Height="22"
                                                     Foreground="White" Margin="-29,0,0,0"/>
                            <TextBlock x:Name="LogoText" Text="Solar WH" FontWeight="Bold"
                                       FontSize="13" Foreground="#FF6D00"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Dashboard -->
                    <Button x:Name="BtnDashboard" Style="{StaticResource SidebarButtonActiveStyle}"
                            Click="Navigate_Dashboard">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtDashboard" Text="Дашборд" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Supplies -->
                    <Button x:Name="BtnSupplies" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Supplies">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="TruckDelivery" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSupplies" Text="Поставки" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Warehouse Items -->
                    <Button x:Name="BtnWarehouse" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Warehouse">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="Warehouse" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtWarehouse" Text="Товари" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Equipment Types -->
                    <Button x:Name="BtnEquipment" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Equipment">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="SolarPanel" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtEquipment" Text="Типи обладнання" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Manufacturers -->
                    <Button x:Name="BtnManufacturers" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Manufacturers">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="Factory" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtManufacturers" Text="Виробники" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Storage Locations -->
                    <Button x:Name="BtnStorage" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Storage">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="MapMarker" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStorage" Text="Місця зберігання" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Admin divider -->
                    <Border x:Name="AdminDivider" Margin="12,8" Height="1" Background="#1F2937"
                            Visibility="Collapsed"/>

                    <!-- Admin section label -->
                    <TextBlock x:Name="AdminLabel" Text="АДМІН" FontSize="10" Foreground="#4B5563"
                               Margin="20,4,12,4" Visibility="Collapsed" Opacity="0"/>

                    <!-- Users (Admin) -->
                    <Button x:Name="BtnUsers" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Users" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtUsers" Text="Користувачі" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- SQL Console (Admin) -->
                    <Button x:Name="BtnSql" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Sql" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="Console" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSql" Text="SQL-консоль" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- DB Structure (Admin) -->
                    <Button x:Name="BtnDbStructure" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_DbStructure" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="DatabaseOutline" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtDbStructure" Text="Структура БД" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Backup/Restore (Admin) -->
                    <Button x:Name="BtnBackup" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Backup" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="DatabaseSync" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBackup" Text="Backup/Restore" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Logs (Admin) -->
                    <Button x:Name="BtnLogs" Style="{StaticResource SidebarButtonStyle}"
                            Click="Navigate_Logs" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="FormatListBulleted" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtLogs" Text="Логи" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Bottom spacer -->
                    <Border Height="16"/>

                    <!-- Theme toggle -->
                    <Button x:Name="BtnTheme" Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnTheme_Click" ToolTip="Перемкнути тему">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon x:Name="ThemeIcon" Kind="WeatherNight" Width="22" Height="22" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTheme" Text="Темна тема" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <!-- Logout -->
                    <Button x:Name="BtnLogout" Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnLogout_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,0,12,0">
                            <materialDesign:PackIcon Kind="Logout" Width="22" Height="22" VerticalAlignment="Center" Foreground="#EF5350"/>
                            <TextBlock x:Name="TxtLogout" Text="Вийти" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="#EF5350"
                                       Visibility="Collapsed" Opacity="0"/>
                        </StackPanel>
                    </Button>

                    <Border Height="12"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Column="1">
            <!-- Dimming overlay when sidebar is expanded -->
            <Border x:Name="DimOverlay" Background="#80000000" Panel.ZIndex="5"
                    Opacity="0" IsHitTestVisible="False">
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Black" Offset="0"/>
                        <GradientStop Color="Black" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>

            <!-- Top bar -->
            <Border Background="#111827" Height="56" VerticalAlignment="Top" Panel.ZIndex="4"
                    BorderBrush="#1F2937" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <TextBlock x:Name="PageTitle" Text="Дашборд" FontSize="18" FontWeight="Bold"
                               Foreground="#FF6D00" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Account" Width="18" Height="18" VerticalAlignment="Center" Foreground="#9E9E9E"/>
                        <TextBlock x:Name="UserLoginLabel" Text="" FontSize="13" Foreground="#9E9E9E"
                                   VerticalAlignment="Center" Margin="6,0,16,0"/>
                        <Border Background="#22FF6D00" CornerRadius="4" Padding="8,3">
                            <TextBlock x:Name="UserRoleLabel" Text="" FontSize="11" Foreground="#FF6D00" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content frame -->
            <Frame x:Name="ContentFrame" Margin="0,56,0,0"
                   NavigationUIVisibility="Hidden"
                   Panel.ZIndex="1"/>
        </Grid>
    </Grid>
</Window>
