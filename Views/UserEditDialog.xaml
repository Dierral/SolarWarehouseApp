<Window x:Class="SolarWarehouseApp.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Користувач"
        Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <StackPanel Margin="24,20">
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold"
                   Foreground="#FF6D00" Margin="0,0,0,20"/>

        <TextBox x:Name="LoginBox"
                 materialDesign:HintAssist.Hint="Логін"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,12" FontSize="13"/>

        <PasswordBox x:Name="PasswordBox"
                     materialDesign:HintAssist.Hint="Пароль"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     Margin="0,0,0,12" FontSize="13"/>

        <ComboBox x:Name="RoleCombo"
                  materialDesign:HintAssist.Hint="Роль"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  Margin="0,0,0,12" FontSize="13"/>

        <CheckBox x:Name="IsActiveCheck" Content="Активний" IsChecked="True"
                  Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#9E9E9E" Click="Cancel_Click" Margin="0,0,8,0">
                Скасувати
            </Button>
            <Button Background="#FF6D00" Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="Ok_Click">
                Зберегти
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
