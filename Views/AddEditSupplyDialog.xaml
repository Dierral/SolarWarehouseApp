<Window x:Class="SolarWarehouseApp.Views.AddEditSupplyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Поставка"
        Width="540" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <materialDesign:PackIcon x:Name="DialogIcon" Kind="TruckDelivery" Width="28" Height="28"
                                     Foreground="#FF6D00" VerticalAlignment="Center"/>
            <TextBlock x:Name="DialogTitle" Text="Нова поставка" FontSize="20" FontWeight="Bold"
                       Foreground="#FF6D00" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Form fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBox x:Name="ArticleBox"
                         materialDesign:HintAssist.Hint="Артикул *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,14" FontSize="14"/>

                <ComboBox x:Name="EquipmentTypeBox"
                          materialDesign:HintAssist.Hint="Тип обладнання *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,14" FontSize="14"
                          DisplayMemberPath="Name"/>

                <ComboBox x:Name="ManufacturerBox"
                          materialDesign:HintAssist.Hint="Виробник *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,14" FontSize="14"
                          DisplayMemberPath="Name"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="QuantityBox"
                             materialDesign:HintAssist.Hint="Кількість *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Grid.Column="0" FontSize="14" Text="1"/>
                    <TextBox x:Name="UnitBox"
                             materialDesign:HintAssist.Hint="Одиниця виміру"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Grid.Column="2" FontSize="14" Text="шт."/>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PowerBox"
                             materialDesign:HintAssist.Hint="Потужність (W)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Grid.Column="0" FontSize="14"/>
                    <TextBox x:Name="VoltageBox"
                             materialDesign:HintAssist.Hint="Напруга (V)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Grid.Column="2" FontSize="14"/>
                </Grid>

                <ComboBox x:Name="StorageLocationBox"
                          materialDesign:HintAssist.Hint="Місце зберігання *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,14" FontSize="14"
                          DisplayMemberPath="Name"/>

                <ComboBox x:Name="SupplyTypeBox"
                          materialDesign:HintAssist.Hint="Тип поставки *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,14" FontSize="14"
                          DisplayMemberPath="Name"/>

                <DatePicker x:Name="SupplyDatePicker"
                            materialDesign:HintAssist.Hint="Дата поставки"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,0,14" FontSize="14"/>

                <TextBox x:Name="SupplierBox"
                         materialDesign:HintAssist.Hint="Постачальник"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,14" FontSize="14"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#9E9E9E" Click="Cancel_Click" Margin="0,0,8,0">
                Скасувати
            </Button>
            <Button Background="#FF6D00" Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="Save_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Зберегти" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
