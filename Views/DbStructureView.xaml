<Page x:Class="SolarWarehouseApp.Views.DbStructureView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesign.Brush.Background}"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: Table tree + Create/Delete table buttons -->
        <materialDesign:Card Grid.Column="0" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF6D00" Padding="12,10" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DatabaseOutline" Width="18" Height="18"
                                                 Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="Таблиці БД" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Table management buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,8,8,4">
                    <Button Background="#FF6D00" Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Click="CreateTable_Click" Margin="0,0,4,0" Padding="8,4"
                            ToolTip="Створити нову таблицю">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TablePlus" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Створити" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Foreground="#EF5350" BorderBrush="#EF5350"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Click="DeleteTable_Click" Padding="8,4"
                            ToolTip="Видалити вибрану таблицю">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TableRemove" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Видалити" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TreeView x:Name="TableTree" Grid.Row="2"
                          Background="Transparent" BorderThickness="0"
                          SelectedItemChanged="TableTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="IsExpanded" Value="False"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </materialDesign:Card>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                      Background="Transparent" ResizeBehavior="PreviousAndNext"/>

        <!-- Right panel: Table details -->
        <materialDesign:Card Grid.Column="2" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF6D00" Padding="12,10" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Table" Width="18" Height="18"
                                                 Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TableNameLabel" Text="Оберіть таблицю зліва"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}"
                            materialDesign:ColorZoneAssist.Mode="PrimaryLight">

                    <!-- ═══ Columns tab ═══ -->
                    <TabItem Header="Поля">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                                <Button Background="#FF6D00" Foreground="White"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="AddColumn_Click" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"/>
                                        <TextBlock Text="Додати поле" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Foreground="#EF5350" BorderBrush="#EF5350"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="DeleteColumn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center"/>
                                        <TextBlock Text="Видалити поле" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <DataGrid x:Name="ColumnsGrid" Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      RowEditEnding="ColumnsGrid_RowEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Назва поля"
                                                        Binding="{Binding ColumnName, UpdateSourceTrigger=LostFocus}"
                                                        Width="*"/>
                                    <DataGridTemplateColumn Header="Тип даних" Width="160" SortMemberPath="DataType">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DataType}" VerticalAlignment="Center" Margin="4,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedItem="{Binding DataType, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding DataContext.SqlDataTypes, RelativeSource={RelativeSource AncestorType=Page}}"
                                                          IsEditable="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="Nullable"
                                                            Binding="{Binding IsNullable, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="80"/>
                                    <DataGridTextColumn Header="За замовчуванням"
                                                        Binding="{Binding DefaultValue, UpdateSourceTrigger=LostFocus}"
                                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- ═══ Primary Keys tab ═══ -->
                    <TabItem Header="Первинні ключі">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                                <Button Background="#FF6D00" Foreground="White"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="AddPk_Click" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="KeyPlus" VerticalAlignment="Center"/>
                                        <TextBlock Text="Додати PK" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Foreground="#EF5350" BorderBrush="#EF5350"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="DeletePk_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="KeyRemove" VerticalAlignment="Center"/>
                                        <TextBlock Text="Видалити PK" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <DataGrid x:Name="PkGrid" Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Style="{StaticResource MaterialDesignDataGrid}"/>
                        </Grid>
                    </TabItem>

                    <!-- ═══ Foreign Keys tab ═══ -->
                    <TabItem Header="Зовнішні ключі">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                                <Button Background="#FF6D00" Foreground="White"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="AddFk_Click" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Link" VerticalAlignment="Center"/>
                                        <TextBlock Text="Додати FK" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Foreground="#EF5350" BorderBrush="#EF5350"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="DeleteFk_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="LinkOff" VerticalAlignment="Center"/>
                                        <TextBlock Text="Видалити FK" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <DataGrid x:Name="FkGrid" Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Style="{StaticResource MaterialDesignDataGrid}"/>
                        </Grid>
                    </TabItem>

                    <!-- ═══ Indexes tab ═══ -->
                    <TabItem Header="Індекси">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                                <Button Background="#FF6D00" Foreground="White"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="AddIndex_Click" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabasePlus" VerticalAlignment="Center"/>
                                        <TextBlock Text="Додати індекс" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Foreground="#EF5350" BorderBrush="#EF5350"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="DeleteIndex_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabaseMinus" VerticalAlignment="Center"/>
                                        <TextBlock Text="Видалити індекс" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <DataGrid x:Name="IndexesGrid" Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Style="{StaticResource MaterialDesignDataGrid}"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
