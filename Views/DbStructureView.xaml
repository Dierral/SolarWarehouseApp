<Page x:Class="SolarWarehouseApp.Views.DbStructureView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesign.Brush.Background}"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: Table tree -->
        <materialDesign:Card Grid.Column="0" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FF6D00" Padding="12,10" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DatabaseOutline" Width="18" Height="18"
                                                 Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="Таблиці БД" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>
                <TreeView x:Name="TableTree" Grid.Row="1"
                          Background="Transparent" BorderThickness="0"
                          SelectedItemChanged="TableTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="IsExpanded" Value="False"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </materialDesign:Card>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                      Background="Transparent" ResizeBehavior="PreviousAndNext"/>

        <!-- Right panel: Table details -->
        <materialDesign:Card Grid.Column="2" UniformCornerRadius="10"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF6D00" Padding="12,10" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Table" Width="18" Height="18"
                                                 Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TableNameLabel" Text="Оберіть таблицю зліва"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}"
                            materialDesign:ColorZoneAssist.Mode="PrimaryLight">
                    <TabItem Header="Поля">
                        <DataGrid x:Name="ColumnsGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource MaterialDesignDataGrid}"/>
                    </TabItem>
                    <TabItem Header="Первинні ключі">
                        <DataGrid x:Name="PkGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource MaterialDesignDataGrid}"/>
                    </TabItem>
                    <TabItem Header="Зовнішні ключі">
                        <DataGrid x:Name="FkGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource MaterialDesignDataGrid}"/>
                    </TabItem>
                    <TabItem Header="Індекси">
                        <DataGrid x:Name="IndexesGrid"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource MaterialDesignDataGrid}"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
